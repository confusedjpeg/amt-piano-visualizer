# Environments and packages
venv/
.venv/
env/
ENV/
.env

# Python caching & artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/

# OS metadata
.DS_Store
Thumbs.db

# Large binary assets (downloaded at setup time, not tracked in git)
assets/fluidsynth/
assets/*.sf2
assets/*.zip

# Run output artifacts in project root
run_*.mp4
run_*.wav
data/input/*
!data/input/.gitkeep

data/intermediate/*
!data/intermediate/.gitkeep

data/output/*
!data/output/.gitkeep

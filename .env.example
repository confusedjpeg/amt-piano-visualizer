# ── AI Piano Pipeline — Environment Variables ──
# Copy this file to .env and adjust values as needed.

# Override the default config file path
# PIANO_CONFIG_PATH=config.yaml

# Force a specific device for ML models (overrides config.yaml)
# PIANO_DEVICE=cuda   # cpu | cuda | auto

# Path to MIDIVisualizer binary (if not on PATH)
# MIDI_VISUALIZER_PATH=/usr/local/bin/MIDIVisualizer

# Log level (DEBUG, INFO, WARNING, ERROR)
# PIANO_LOG_LEVEL=INFO
